# ─── SERVER ───────────────────────────────────────────────────────
# Host and port for the FastAPI backend (default: 127.0.0.1:8000)
HOST=127.0.0.1
PORT=8000

# ─── EXTERNAL SERVICE HOSTS ────────────────────────────────────────
# Qdrant vector database for long-term memory
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Redis for LangGraph checkpointing/session persistence
REDIS_URL=redis://localhost:6379

# ─── CLOUD LLM (OPTIONAL) ──────────────────────────────────────────
# DeepSeek API key for cloud escalation fallback
DEEPSEEK_API_KEY=

# ─── MODEL CONFIGURATION ───────────────────────────────────────────
# LM Studio base URLs for small/medium/cloud model slots
# Usually all point to the same LM Studio instance
SMALL_LLM_BASE_URL=http://127.0.0.1:1234/v1
MEDIUM_LLM_BASE_URL=http://127.0.0.1:1234/v1
CLOUD_LLM_BASE_URL=

# Model names as loaded in LM Studio (or your provider)
SMALL_LLM_MODEL_NAME=gemma-4-e2b-heretic-uncensored-mlx
MEDIUM_LLM_MODEL_NAME=lfm2-8b-a1b-absolute-heresy-mpoa-mlx
CLOUD_LLM_MODEL_NAME=deepseek-chat

# Context window for the long-context medium model variant
# MEDIUM_LONGCTX_CONTEXT=131072

# Machine type: set OPTIMIZE_FOR_M4=true on Mac M4 Air
# MACHINE_TYPE=M4_MAC
OPTIMIZE_FOR_M4=false

# ─── WEB SEARCH ────────────────────────────────────────────────────
# Provider routing: auto | brave | serper | tavily | none
# WEB_SEARCH_PROVIDER=auto
# WEB_SEARCH_TIMEOUT_SECONDS=22

# Enable Playwright browser fallback for web scraping
# WEB_SEARCH_ENABLE_BROWSER_FALLBACK=true

# Tier-1 provider API keys (optional — auto-routes if configured)
# BRAVE_SEARCH_API_KEY=
# SERPER_API_KEY=
# TAVILY_API_KEY=

# Self-hosted SearXNG metasearch (recommended for local setups)
# SEARXNG_URL=http://localhost:8888

# ─── WEB RAG ───────────────────────────────────────────────────────
# WEB_RAG_ENABLED=true
# WEB_RAG_EMBED_MODEL=text-embedding-nomic-embed-text-v1.5@f16
# WEB_RAG_TOP_K=5
